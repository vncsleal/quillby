# Quillby runtime
QUILLBY_HOME=~/.quillby

# Transport: stdio (default) or http
Quillby_TRANSPORT=stdio
PORT=3000
QUILLBY_HTTP_HOST=0.0.0.0
QUILLBY_BASE_URL=http://localhost:3000

# Better Auth / libSQL (local default)
QUILLBY_AUTH_DB_URL=file:./quillby-auth.db
# For remote libSQL/Turso only
LIBSQL_AUTH_TOKEN=

# Better Auth base URL (recommended in HTTP mode)
BETTER_AUTH_URL=http://localhost:3000

# Default per-key API rate limit (requests per minute)
QUILLBY_RATE_LIMIT=60
