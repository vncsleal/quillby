# OpenAI Configuration
OPENAI_API_KEY=sk-...

# Model Selection (2026 Latest Models)
# FAST: gpt-5-mini (filtering, scoring - fast & economical)
# STANDARD: gpt-5.2 (general purpose - latest GPT-5 with broad world knowledge)
# ADVANCED: gpt-5.2 (research & analysis - best quality)
# REASONING: o3 (deep multi-step reasoning - highest reasoning level)
# PRO: gpt-5.2-pro (complex analysis with extended compute - optional)

LLM_MODEL_FAST=gpt-5-mini
LLM_MODEL=gpt-5.2
LLM_MODEL_RESEARCH=gpt-5.2
LLM_MODEL_REASONING=o3
LLM_MODEL_PRO=gpt-5.2-pro

# Parallelization Settings
# Number of concurrent workers for parallel processing (default: 4)
PARALLEL_WORKERS=4

# Batch size for processing items (default: 10)
BATCH_SIZE=10

# Parallel requests per concurrent call (default: 5)
PARALLEL_REQUESTS=5

# Embeddings & Vector Store
# Use text-embedding-3-large for semantic search (default)
EMBEDDING_MODEL=text-embedding-3-large

# Enable vector store for semantic deduplication (default: false)
USE_VECTOR_STORE=false
