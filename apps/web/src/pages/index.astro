---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';

const curlCommand = `curl -fsSL https://raw.githubusercontent.com/vncsleal/quillby/main/install.sh | bash`;

const claudeConfig = `{
  "mcpServers": {
    "quillby": {
      "command": "quillby-mcp"
    }
  }
}`;

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/quillby.png" type="image/png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary SEO -->
    <title>Quillby — Your AI Content Agent</title>
    <meta name="description" content="Quillby reads your feeds, filters what matters, and delivers fresh drafts in your voice — with one workspace per project, client, or brand." />
    <link rel="canonical" href="https://quillby.vercel.app/" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://quillby.vercel.app/" />
    <meta property="og:title" content="Quillby — Your AI Content Agent" />
    <meta property="og:description" content="Reads the internet. Filters for you. Writes in your voice, with one workspace per project." />
    <meta property="og:image" content="https://quillby.vercel.app/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Quillby — Your AI Content Agent" />
    <meta property="og:site_name" content="Quillby" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Quillby — Your AI Content Agent" />
    <meta name="twitter:description" content="Reads the internet. Filters for you. Writes in your voice, with one workspace per project." />
    <meta name="twitter:image" content="https://quillby.vercel.app/og.png" />
    <meta name="twitter:image:alt" content="Quillby — Your AI Content Agent" />

    <!-- Indexing -->
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#0c0915" />
    <Analytics />
    <style>
      :root {
        --bg:        #0c0915;
        --bg-1:      #110d1e;
        --bg-2:      #16102a;
        --surface:   rgba(255,255,255,0.04);
        --surface-h: rgba(255,255,255,0.07);
        --border:    rgba(167,139,250,0.12);
        --border-h:  rgba(167,139,250,0.28);
        --violet:    #a78bfa;
        --violet-2:  #7c3aed;
        --violet-3:  #c4b5fd;
        --amber:     #fbbf24;
        --text:      #f0eafa;
        --muted:     rgba(240,234,250,0.45);
        --faint:     rgba(240,234,250,0.2);
        --serif:     'Fraunces', Georgia, serif;
        --sans:      'Nunito', system-ui, sans-serif;
        --mono:      'DM Mono', monospace;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--sans);
        font-size: 16px;
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }

      /* Noise overlay */
      body::after {
        content: '';
        position: fixed;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
        pointer-events: none;
        z-index: 9998;
      }

      /* Radial glow backdrop */
      .glow-bg {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        overflow: hidden;
      }
      .glow-bg::before {
        content: '';
        position: absolute;
        top: -20%; left: 50%;
        transform: translateX(-50%);
        width: 900px; height: 600px;
        background: radial-gradient(ellipse at center, rgba(124,58,237,0.18) 0%, transparent 70%);
        filter: blur(40px);
      }
      .glow-bg::after {
        content: '';
        position: absolute;
        bottom: 10%; right: -10%;
        width: 500px; height: 500px;
        background: radial-gradient(ellipse at center, rgba(167,139,250,0.08) 0%, transparent 65%);
        filter: blur(60px);
      }

      /* NAV */
      nav {
        position: sticky; top: 0; z-index: 200;
        padding: 0 clamp(1.5rem, 5vw, 5rem);
        height: 60px;
        display: flex; align-items: center; justify-content: space-between;
        isolation: isolate;
      }
      nav::before {
        content: '';
        position: absolute;
        inset: 0;
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        background: rgba(12,9,21,0.4);
        -webkit-mask-image: linear-gradient(to bottom, black 40%, transparent 100%);
        mask-image: linear-gradient(to bottom, black 40%, transparent 100%);
        pointer-events: none;
        z-index: -1;
      }
      .nav-logo {
        display: flex; align-items: center; gap: 10px;
        text-decoration: none; color: var(--text);
      }
      .nav-logo img {
        width: 34px; height: 34px; border-radius: 50%; object-fit: cover;
        box-shadow: 0 0 14px rgba(167,139,250,0.45);
      }
      .nav-logo-name {
        font-family: var(--serif); font-size: 1.2rem; font-weight: 600; letter-spacing: -0.01em;
      }
      .nav-links { display: flex; align-items: center; gap: 2rem; list-style: none; }
      .nav-links a {
        font-size: 0.8125rem; font-weight: 500; color: var(--muted);
        text-decoration: none; letter-spacing: 0.02em; transition: color 0.15s;
      }
      .nav-links a:hover { color: var(--text); }
      .nav-pill {
        background: linear-gradient(135deg, var(--violet-2), var(--violet));
        color: #fff !important; padding: 0.45rem 1.2rem; border-radius: 100px;
        font-weight: 700 !important;
        box-shadow: 0 0 18px rgba(124,58,237,0.4);
        transition: box-shadow 0.2s, transform 0.15s !important;
      }
      .nav-pill:hover { transform: translateY(-1px); box-shadow: 0 0 28px rgba(124,58,237,0.6) !important; }

      /* HERO */
      .hero {
        position: relative; z-index: 1;
        min-height: calc(100vh - 60px);
        display: flex; align-items: center;
        padding: clamp(4rem, 10vh, 8rem) clamp(1.5rem, 5vw, 5rem);
        gap: 4rem; max-width: 1340px; margin: 0 auto;
      }
      .hero-content { flex: 1 1 520px; display: flex; flex-direction: column; gap: 2rem; }

      
      @keyframes pulse-dot { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.6;transform:scale(0.8)} }

      .hero-headline {
        font-family: var(--serif);
        font-size: clamp(3rem, 6vw, 5.5rem);
        font-weight: 800; line-height: 1.0; letter-spacing: -0.025em; color: var(--text);
      }
      .hero-headline em { font-style: italic; font-weight: 300; color: var(--violet-3); }

      .hero-sub {
        font-size: 1.075rem; color: var(--muted); max-width: 46ch; line-height: 1.75;
      }
      .hero-sub strong { color: var(--text); font-weight: 600; }

      .hero-actions { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; padding-top: 0.5rem; }

      .btn-primary {
        display: inline-flex; align-items: center; gap: 0.5rem;
        padding: 0.85rem 2rem;
        background: linear-gradient(135deg, var(--violet-2) 0%, #9333ea 100%);
        color: #fff; font-family: var(--sans); font-size: 0.9375rem; font-weight: 700;
        border-radius: 10px; text-decoration: none; border: none; cursor: pointer;
        box-shadow: 0 0 28px rgba(124,58,237,0.45), 0 4px 20px rgba(124,58,237,0.3);
        transition: box-shadow 0.2s, transform 0.15s; letter-spacing: 0.01em;
      }
      .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 0 44px rgba(124,58,237,0.65), 0 8px 32px rgba(124,58,237,0.45); }

      .btn-secondary {
        display: inline-flex; align-items: center; gap: 0.5rem;
        padding: 0.85rem 1.75rem; background: var(--surface); color: var(--muted);
        font-family: var(--sans); font-size: 0.9375rem; font-weight: 600;
        border-radius: 10px; text-decoration: none; border: 1px solid var(--border); cursor: pointer;
        transition: background 0.2s, color 0.2s, border-color 0.2s, transform 0.15s;
      }
      .btn-secondary:hover { background: var(--surface-h); color: var(--text); border-color: var(--border-h); transform: translateY(-1px); }

      .hero-proof {
        display: flex; align-items: center; gap: 0.75rem;
        font-size: 0.8125rem; color: var(--faint); font-weight: 500;
      }
      .hero-proof::before { content:''; width:28px; height:1px; background:var(--faint); flex-shrink:0; }

      /* Hero visual — mascot only */
      .hero-visual {
        flex: 1 1 420px; position: relative;
        display: flex; align-items: center; justify-content: center;
        min-height: 400px;
      }
      .mascot-scene {
        position: relative;
        width: 380px; height: 380px;
        display: flex; align-items: center; justify-content: center;
      }
      /* Slow-spin orbit ring */
      .mascot-ring {
        position: absolute; inset: 0; border-radius: 50%;
        border: 1px solid rgba(167,139,250,0.13);
        animation: ring-spin 22s linear infinite;
      }
      .mascot-ring::before, .mascot-ring::after {
        content: ''; position: absolute;
        width: 9px; height: 9px; border-radius: 50%;
        background: var(--violet); box-shadow: 0 0 12px var(--violet);
        top: 50%; left: -4.5px; transform: translateY(-50%);
      }
      .mascot-ring::after {
        left: auto; right: -3px;
        background: var(--violet-3); box-shadow: 0 0 8px var(--violet-3);
        width: 6px; height: 6px;
      }
      @keyframes ring-spin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }
      /* Second ring, counter-spin */
      .mascot-ring2 {
        position: absolute; inset: 14%; border-radius: 50%;
        border: 1px dashed rgba(167,139,250,0.07);
        animation: ring-spin 14s linear infinite reverse;
      }
      /* Glow pulse */
      .mascot-glow {
        position: absolute; inset: 18%; border-radius: 50%;
        background: radial-gradient(circle, rgba(124,58,237,0.3) 0%, rgba(167,139,250,0.08) 50%, transparent 72%);
        filter: blur(22px);
        animation: glow-pulse 3.5s ease-in-out infinite;
      }
      @keyframes glow-pulse {
        0%,100% { transform:scale(1); opacity:0.7; }
        50% { transform:scale(1.18); opacity:1; }
      }
      .mascot-img {
        position: relative; z-index: 2;
        width: 250px; height: 250px; object-fit: contain;
        filter: drop-shadow(0 16px 48px rgba(124,58,237,0.6)) drop-shadow(0 0 24px rgba(167,139,250,0.35));
        animation: float 4.5s ease-in-out infinite;
      }
      @keyframes float {
        0%,100% { transform:translateY(0px) rotate(-1deg); }
        50% { transform:translateY(-16px) rotate(1deg); }
      }
      /* SVG sparkles */
      .sparkle-svg {
        position: absolute; pointer-events: none; z-index: 3;
        animation: sp-anim var(--dur,2.5s) ease-in-out infinite var(--delay,0s);
        opacity: 0;
      }
      @keyframes sp-anim {
        0%,100% { opacity:0; transform:scale(0.3) rotate(0deg); }
        50% { opacity:1; transform:scale(1) rotate(30deg); }
      }
      .sp1 { top:4%; right:16%; --dur:2.4s; --delay:0s; width:18px; }
      .sp2 { top:18%; left:6%; --dur:3.2s; --delay:0.8s; width:13px; }
      .sp3 { bottom:16%; right:8%; --dur:2.8s; --delay:1.4s; width:15px; }
      .sp4 { bottom:8%; left:18%; --dur:2.1s; --delay:0.3s; width:11px; }
      .sp5 { top:52%; right:3%; --dur:3.6s; --delay:2s; width:12px; }
      .sp6 { top:32%; left:2%; --dur:2.6s; --delay:1s; width:10px; }
      /* Audience floating tags */
      .audience-tag {
        position: absolute; z-index: 3;
        padding: 0.35rem 0.8rem;
        background: rgba(17,13,30,0.9); backdrop-filter: blur(8px);
        border: 1px solid var(--border); border-radius: 100px;
        font-size: 0.7rem; font-weight: 600; color: var(--violet-3);
        letter-spacing: 0.03em; white-space: nowrap;
        display: flex; align-items: center; gap: 0.45rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.35), 0 0 12px rgba(124,58,237,0.1);
        animation: tag-float var(--tdur,5s) ease-in-out infinite var(--tdelay,0s);
      }
      @keyframes tag-float {
        0%,100% { transform:translateY(0px); }
        50% { transform:translateY(-7px); }
      }
      .tag-dot { width:5px; height:5px; border-radius:50%; background:var(--violet); box-shadow:0 0 5px var(--violet); flex-shrink:0; }
      .at1 { top:6%; left:-5%; --tdur:5.2s; --tdelay:0s; }
      .at2 { top:6%; right:-8%; --tdur:4.8s; --tdelay:0.9s; }
      .at3 { bottom:10%; left:0%; --tdur:5.5s; --tdelay:1.6s; }

      /* MARQUEE */
      .marquee-wrap {
        position:relative; z-index:1;
        border-top:1px solid var(--border); border-bottom:1px solid var(--border);
        padding:0.85rem 0; overflow:hidden; background:rgba(255,255,255,0.02);
      }
      .marquee-track { display:inline-flex; gap:0; animation:marquee 28s linear infinite; white-space:nowrap; }
      @keyframes marquee { from{transform:translateX(0)} to{transform:translateX(-50%)} }
      .marquee-item {
        display:inline-flex; align-items:center; gap:1.25rem; padding:0 1.75rem;
        font-family:var(--mono); font-size:0.6875rem; letter-spacing:0.1em;
        text-transform:uppercase; color:var(--faint);
      }
      .marquee-dot { color:var(--violet); font-size:0.5rem; }

      /* SHARED SECTION STYLES */
      .container { position:relative; z-index:1; max-width:1200px; margin:0 auto; padding:0 clamp(1.5rem,5vw,5rem); }

      .eyebrow {
        display:inline-flex; align-items:center; gap:0.6rem;
        font-family:var(--mono); font-size:0.6875rem; letter-spacing:0.13em;
        text-transform:uppercase; color:var(--violet); margin-bottom:1.25rem;
      }
      .eyebrow::before { content:''; width:18px; height:1px; background:var(--violet); opacity:0.6; }

      .sec-title {
        font-family:var(--serif); font-size:clamp(2.4rem,4vw,3.75rem); font-weight:800;
        line-height:1.05; letter-spacing:-0.02em; color:var(--text); margin-bottom:1.25rem;
      }
      .sec-title em { font-style:italic; font-weight:300; color:var(--violet-3); }
      .sec-body { font-size:1.0625rem; color:var(--muted); max-width:52ch; line-height:1.75; }

      /* PROBLEM/SOLUTION */
      .mode-sec { padding:clamp(4rem,8vw,7rem) 0; border-bottom:1px solid var(--border); }
      .mode-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; margin-top:3rem; }
      .mode-card {
        background:linear-gradient(180deg, rgba(17,13,30,0.95), rgba(12,9,21,0.96));
        border:1px solid var(--border);
        border-radius:16px;
        padding:2rem;
        display:flex;
        flex-direction:column;
        gap:1rem;
        min-height:280px;
        transition:border-color 0.25s, transform 0.2s, box-shadow 0.25s;
      }
      .mode-card:hover { border-color:var(--border-h); transform:translateY(-3px); box-shadow:0 16px 50px rgba(0,0,0,0.3), 0 0 24px rgba(124,58,237,0.08); }
      .mode-kicker { font-family:var(--mono); font-size:0.65rem; letter-spacing:0.14em; text-transform:uppercase; color:var(--violet); opacity:0.8; }
      .mode-name { font-family:var(--serif); font-size:1.45rem; font-weight:700; letter-spacing:-0.02em; color:var(--text); }
      .mode-desc { font-size:0.9rem; color:var(--muted); line-height:1.7; flex:1; }
      .mode-list { list-style:none; display:flex; flex-direction:column; gap:0.55rem; font-size:0.8rem; color:var(--faint); }
      .mode-list li strong { color:var(--text); font-weight:600; }
      .mode-link { display:inline-flex; align-items:center; gap:0.4rem; text-decoration:none; color:var(--violet-3); font-weight:700; font-size:0.88rem; }

      /* PROBLEM/SOLUTION */
      .problem-sec { padding:clamp(5rem,9vw,9rem) 0; border-bottom:1px solid var(--border); }
      .ps-grid {
        display:grid; grid-template-columns:1fr 1fr; gap:2px;
        margin-top:3.5rem; border-radius:16px; overflow:hidden; border:1px solid var(--border);
      }
      .ps-col { background:var(--bg-1); padding:clamp(2rem,4vw,3.5rem); position:relative; }
      .ps-col:first-child { border-right:1px solid var(--border); }
      .ps-col::before { content:''; position:absolute; top:0;left:0;right:0; height:2px; }
      .ps-col.before::before { background:linear-gradient(90deg, rgba(239,68,68,0.5), transparent); }
      .ps-col.after::before { background:linear-gradient(90deg, rgba(167,139,250,0.6), transparent); }
      .ps-tag {
        font-family:var(--mono); font-size:0.625rem; letter-spacing:0.15em; text-transform:uppercase;
        padding:0.3rem 0.7rem; border-radius:4px; display:inline-block; margin-bottom:2rem; font-weight:500;
      }
      .ps-tag.before { color:#fca5a5; background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.2); }
      .ps-tag.after { color:var(--violet-3); background:rgba(167,139,250,0.08); border:1px solid var(--border); }
      .ps-list { list-style:none; display:flex; flex-direction:column; gap:1.1rem; }
      .ps-list li { display:flex; gap:1rem; font-size:0.9375rem; color:var(--muted); line-height:1.6; }
      .ps-icon { flex-shrink:0; font-size:0.875rem; margin-top:0.1rem; opacity:0.7; }
      .ps-list li strong { color:var(--text); font-weight:600; }

      /* HOW IT WORKS */
      .how-sec { padding:clamp(5rem,9vw,9rem) 0; border-bottom:1px solid var(--border); }
      .steps-row { display:grid; grid-template-columns:repeat(4,1fr); gap:1.5rem; margin-top:4rem; }
      .step-card {
        background:var(--bg-1); border:1px solid var(--border); border-radius:14px;
        padding:2rem 1.75rem; position:relative; overflow:hidden;
        transition:border-color 0.25s, transform 0.2s, box-shadow 0.25s;
      }
      .step-card::before {
        content:''; position:absolute; inset:0;
        background:radial-gradient(ellipse at top left, rgba(124,58,237,0.07) 0%, transparent 60%);
        pointer-events:none;
      }
      .step-card:hover { border-color:var(--border-h); transform:translateY(-4px); box-shadow:0 20px 60px rgba(0,0,0,0.35), 0 0 30px rgba(124,58,237,0.1); }
      .step-num { font-family:var(--mono); font-size:0.625rem; letter-spacing:0.12em; color:var(--violet); opacity:0.6; margin-bottom:1.5rem; }
      .step-glyph { font-size:1.75rem; margin-bottom:1rem; display:block; line-height:1; }
      .step-title { font-family:var(--serif); font-size:1.15rem; font-weight:600; color:var(--text); margin-bottom:0.6rem; line-height:1.25; }
      .step-desc { font-size:0.875rem; color:var(--muted); line-height:1.7; }

      /* FEATURES */
      .feat-sec { padding:clamp(5rem,9vw,9rem) 0; border-bottom:1px solid var(--border); }
      .feat-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; margin-top:4rem; }
      .feat-card {
        background:var(--bg-1); border:1px solid var(--border); border-radius:14px;
        padding:2.25rem 2rem; transition:border-color 0.25s, transform 0.2s, box-shadow 0.25s;
        position:relative; overflow:hidden;
      }
      .feat-card::after {
        content:''; position:absolute; bottom:0;left:0;right:0; height:1px;
        background:linear-gradient(90deg, transparent, rgba(167,139,250,0.2), transparent);
        opacity:0; transition:opacity 0.25s;
      }
      .feat-card:hover { border-color:var(--border-h); transform:translateY(-3px); box-shadow:0 16px 50px rgba(0,0,0,0.3), 0 0 24px rgba(124,58,237,0.08); }
      .feat-card:hover::after { opacity:1; }
      .feat-icon {
        width:44px; height:44px; border-radius:10px;
        background:rgba(124,58,237,0.15); border:1px solid rgba(167,139,250,0.2);
        display:flex; align-items:center; justify-content:center; font-size:1.25rem; margin-bottom:1.25rem;
      }
      .feat-title { font-family:var(--serif); font-size:1.1rem; font-weight:600; color:var(--text); margin-bottom:0.6rem; }
      .feat-desc { font-size:0.875rem; color:var(--muted); line-height:1.7; }

      /* INSTALL */
      .install-sec { padding:clamp(5rem,9vw,9rem) 0; border-bottom:1px solid var(--border); }
      .install-wrap { display:grid; grid-template-columns:1fr 1fr; gap:3rem; margin-top:4rem; align-items:start; }
      .os-tabs-wrap {
        display:flex; gap:0;
        background:var(--surface); border:1px solid var(--border); border-radius:8px;
        overflow:hidden; width:fit-content; margin-bottom:1.5rem;
      }
      .os-tab {
        padding:0.5rem 1.1rem; background:transparent; border:none; border-right:1px solid var(--border);
        color:var(--muted); font-family:var(--mono); font-size:0.75rem; letter-spacing:0.04em;
        cursor:pointer; transition:background 0.15s, color 0.15s;
      }
      .os-tab:last-child { border-right:none; }
      .os-tab.active { background:linear-gradient(135deg, rgba(124,58,237,0.35), rgba(124,58,237,0.15)); color:var(--violet-3); }
      .code-block { background:var(--bg-2); border:1px solid var(--border); border-radius:10px; overflow:hidden; margin-bottom:1rem; }
      .code-top { display:flex; align-items:center; justify-content:space-between; padding:0.6rem 1rem; border-bottom:1px solid rgba(167,139,250,0.07); }
      .code-lang { font-family:var(--mono); font-size:0.625rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--faint); }
      .copy-btn {
        font-family:var(--mono); font-size:0.6875rem; letter-spacing:0.05em;
        background:none; border:1px solid rgba(167,139,250,0.2); color:var(--muted);
        border-radius:4px; padding:0.2rem 0.65rem; cursor:pointer;
        transition:color 0.15s, border-color 0.15s;
      }
      .copy-btn:hover { color:var(--violet-3); border-color:var(--border-h); }
      .code-body { padding:1.1rem 1.25rem; font-family:var(--mono); font-size:0.8rem; color:rgba(240,234,250,0.75); overflow-x:auto; line-height:1.8; }
      .dl-btn {
        display:flex; align-items:center; justify-content:center; gap:0.5rem;
        width:100%; padding:0.9rem 1.5rem;
        background:linear-gradient(135deg, var(--violet-2), #9333ea);
        color:#fff; font-family:var(--sans); font-size:0.9rem; font-weight:700;
        border-radius:10px; text-decoration:none; border:none; cursor:pointer;
        box-shadow:0 0 24px rgba(124,58,237,0.4);
        transition:box-shadow 0.2s, transform 0.15s; margin-bottom:0.75rem;
      }
      .dl-btn:hover { transform:translateY(-2px); box-shadow:0 0 40px rgba(124,58,237,0.6); }
      .install-note { font-size:0.75rem; color:var(--faint); line-height:1.6; }
      .install-steps { display:flex; flex-direction:column; gap:2rem; }
      .install-step { display:flex; gap:1.1rem; align-items:flex-start; }
      .install-step-num {
        flex-shrink:0; width:28px; height:28px; border-radius:50%;
        border:1px solid var(--border); background:var(--surface);
        display:flex; align-items:center; justify-content:center;
        font-family:var(--mono); font-size:0.625rem; color:var(--violet); margin-top:0.15rem;
      }
      .install-step-body h4 { font-size:0.9375rem; font-weight:600; color:var(--text); margin-bottom:0.35rem; }
      .install-step-body p { font-size:0.8375rem; color:var(--muted); line-height:1.65; }
      .prompt-callout {
        margin-top:2rem; padding:1.25rem 1.5rem;
        border:1px solid rgba(167,139,250,0.2); border-radius:10px;
        background:rgba(124,58,237,0.06);
      }
      .prompt-callout-label { font-family:var(--mono); font-size:0.6rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--violet); margin-bottom:0.6rem; opacity:0.7; }
      .prompt-callout-text { font-family:var(--serif); font-size:1.05rem; font-style:italic; color:var(--text); }

      /* INDUSTRIES */
      .ind-sec { padding:clamp(5rem,9vw,9rem) 0; border-bottom:1px solid var(--border); }
      .ind-grid {
        display:grid; grid-template-columns:repeat(4,1fr); gap:1px;
        background:var(--border); border:1px solid var(--border);
        border-radius:14px; overflow:hidden; margin-top:3.5rem;
      }
      .ind-card { background:var(--bg); padding:1.75rem 1.5rem; display:flex; flex-direction:column; gap:0.65rem; transition:background 0.2s; }
      .ind-card:hover { background:var(--bg-1); }
      .ind-g { display:block; margin-bottom:0.25rem; }
      .ind-t { font-size:0.875rem; font-weight:600; color:var(--text); }
      .ind-d { font-size:0.8rem; color:var(--muted); line-height:1.6; }

      /* STATEMENT */
      .statement-sec {
        position:relative; z-index:1;
        padding:clamp(6rem,12vw,11rem) clamp(1.5rem,5vw,5rem); text-align:center; overflow:hidden;
      }
      .statement-sec::before {
        content:''; position:absolute; top:50%;left:50%; transform:translate(-50%,-50%);
        width:800px; height:400px;
        background:radial-gradient(ellipse, rgba(124,58,237,0.15) 0%, transparent 65%);
        filter:blur(50px); pointer-events:none;
      }
      .statement-q {
        font-family:var(--serif); font-size:clamp(2.2rem,5vw,4.25rem); font-weight:800;
        line-height:1.1; letter-spacing:-0.02em; color:var(--text); max-width:22ch;
        margin:0 auto 2.5rem; position:relative;
      }
      .statement-q em { font-style:italic; font-weight:300; color:var(--violet-3); }

      /* FOOTER */
      footer {
        position:relative; z-index:1;
        border-top:1px solid var(--border); padding:2rem clamp(1.5rem,5vw,5rem);
        display:flex; align-items:center; justify-content:space-between;
        font-size:0.8125rem; color:var(--muted);
      }
      footer a { color:var(--muted); text-decoration:none; transition:color 0.15s; }
      footer a:hover { color:var(--text); }
      .footer-brand { display:flex; align-items:center; gap:0.6rem; }
      .footer-brand img { width:20px; height:20px; border-radius:50%; object-fit:cover; opacity:0.5; }
      .footer-links { display:flex; gap:1.75rem; }

      /* REVEAL */
      [data-reveal] { opacity:0; transform:translateY(16px); transition:opacity 0.6s cubic-bezier(0.22,1,0.36,1), transform 0.6s cubic-bezier(0.22,1,0.36,1); }
      [data-reveal].revealed { opacity:1; transform:none; }
      [data-reveal]:nth-child(2){transition-delay:0.07s}
      [data-reveal]:nth-child(3){transition-delay:0.14s}
      [data-reveal]:nth-child(4){transition-delay:0.21s}
      [data-reveal]:nth-child(5){transition-delay:0.28s}
      [data-reveal]:nth-child(6){transition-delay:0.35s}
      [data-reveal]:nth-child(7){transition-delay:0.42s}
      [data-reveal]:nth-child(8){transition-delay:0.49s}
      [data-reveal]:nth-child(9){transition-delay:0.56s}
      [data-reveal]:nth-child(10){transition-delay:0.63s}
      [data-reveal]:nth-child(11){transition-delay:0.70s}
      [data-reveal]:nth-child(12){transition-delay:0.77s}

      .hidden { display:none !important; }

      /* RESPONSIVE */
      @media (max-width:1024px) {
        .mode-grid { grid-template-columns:1fr; }
        .steps-row { grid-template-columns:1fr 1fr; }
        .feat-grid { grid-template-columns:1fr 1fr; }
        .ind-grid { grid-template-columns:repeat(3,1fr); }
      }
      @media (max-width:800px) {
        .hero { flex-direction:column; gap:3rem; }
        .hero-visual { width:100%; }
        .ps-grid { grid-template-columns:1fr; }
        .ps-col:first-child { border-right:none; border-bottom:1px solid var(--border); }
        .install-wrap { grid-template-columns:1fr; }
        .ind-grid { grid-template-columns:1fr 1fr; }
      }
      @media (max-width:560px) {
        .steps-row { grid-template-columns:1fr; }
        .feat-grid { grid-template-columns:1fr; }
        .ind-grid { grid-template-columns:1fr; }
        .nav-links li:not(:last-child) { display:none; }
        .hero-actions { flex-direction:column; align-items:flex-start; }
      }
    </style>
  </head>

  <body>
    <div class="glow-bg" aria-hidden="true"></div>

    <!-- NAV -->
    <nav>
      <a href="/" class="nav-logo">
        <img src="/quillby.png" alt="Quillby" />
        <span class="nav-logo-name">Quillby</span>
      </a>
      <ul class="nav-links">
        <li><a href="#how-it-works">How it works</a></li>
        <li><a href="#modes">Modes</a></li>
        <li><a href="https://github.com/vncsleal/quillby" target="_blank" rel="noopener">GitHub</a></li>
        <li><a href="/local" class="nav-pill">Install free</a></li>
      </ul>
    </nav>

    <!-- HERO -->
    <section class="hero">
      <div class="hero-content">
        
        <h1 class="hero-headline">
          The internet<br />
          already wrote<br />
          <em>your next post.</em>
        </h1>
        <p class="hero-sub">
          Ask Claude <strong>"what should I post today?"</strong> and get a ranked brief and a ready-to-publish draft — sourced from your feeds, filtered for your audience, written in your voice. Use one workspace per client, brand, newsletter, or Claude Project.
        </p>
        <div class="hero-actions">
          <a href="/local" class="btn-primary">Install locally →</a>
          <a href="/cloud" class="btn-secondary">Explore cloud ↗</a>
        </div>
        <p class="hero-proof">Free forever · Local-first · Multiple workspaces · No new apps</p>
      </div>

      <div class="hero-visual">
        <div class="mascot-scene">
          <div class="mascot-ring"></div>
          <div class="mascot-ring2"></div>
          <div class="mascot-glow"></div>
          <!-- SVG sparkle stars -->
          <svg class="sparkle-svg sp1" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2L13.5 9.5L21 11L13.5 12.5L12 20L10.5 12.5L3 11L10.5 9.5L12 2Z" fill="#c4b5fd" opacity="0.9"/></svg>
          <svg class="sparkle-svg sp2" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2L13.5 9.5L21 11L13.5 12.5L12 20L10.5 12.5L3 11L10.5 9.5L12 2Z" fill="#a78bfa" opacity="0.7"/></svg>
          <svg class="sparkle-svg sp3" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2L13.5 9.5L21 11L13.5 12.5L12 20L10.5 12.5L3 11L10.5 9.5L12 2Z" fill="#c4b5fd" opacity="0.8"/></svg>
          <svg class="sparkle-svg sp4" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2L13.5 9.5L21 11L13.5 12.5L12 20L10.5 12.5L3 11L10.5 9.5L12 2Z" fill="#a78bfa" opacity="0.6"/></svg>
          <svg class="sparkle-svg sp5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2L13.5 9.5L21 11L13.5 12.5L12 20L10.5 12.5L3 11L10.5 9.5L12 2Z" fill="#c4b5fd" opacity="0.65"/></svg>
          <svg class="sparkle-svg sp6" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2L13.5 9.5L21 11L13.5 12.5L12 20L10.5 12.5L3 11L10.5 9.5L12 2Z" fill="#a78bfa" opacity="0.5"/></svg>
          <img src="/quillby.png" alt="Quillby mascot" class="mascot-img" />
        </div>
      </div>
    </section>

    <section class="mode-sec" id="modes">
      <div class="container">
        <div class="eyebrow">Choose your mode</div>
        <h2 class="sec-title">One product.<br /><em>Three deployment models.</em></h2>
        <p class="sec-body">Quillby runs locally in Claude, on your own infrastructure, or as a managed cloud service. Pick the operating model first, then follow the setup path built for it.</p>
        <div class="mode-grid">
          <article data-reveal class="mode-card">
            <div class="mode-kicker">Default</div>
            <h3 class="mode-name">Local</h3>
            <p class="mode-desc">Install Quillby on your machine and let Claude Desktop or another stdio-capable MCP client run it locally. No account. No server. Your workspace data stays under <code>~/.quillby</code>.</p>
            <ul class="mode-list">
              <li><strong>Best for:</strong> solo local-first use</li>
              <li><strong>Transport:</strong> stdio MCP</li>
              <li><strong>Setup:</strong> installer, script, or npm</li>
            </ul>
            <a href="/local" class="mode-link">Open local setup →</a>
          </article>
          <article data-reveal class="mode-card">
            <div class="mode-kicker">Bring your own infra</div>
            <h3 class="mode-name">Self-Host</h3>
            <p class="mode-desc">Deploy the Quillby HTTP server yourself with Docker or your own platform, then connect Claude.ai custom connectors, ChatGPT/OpenAI tooling, or the Quillby dashboard to your endpoint.</p>
            <ul class="mode-list">
              <li><strong>Best for:</strong> technical teams and agencies</li>
              <li><strong>Transport:</strong> HTTPS MCP endpoint</li>
              <li><strong>Setup:</strong> Docker-first</li>
            </ul>
            <a href="/self-host" class="mode-link">Open self-host guide →</a>
          </article>
          <article data-reveal class="mode-card">
            <div class="mode-kicker">Managed</div>
            <h3 class="mode-name">Cloud</h3>
            <p class="mode-desc">Use Quillby as a hosted service with a managed dashboard, billing, and connector onboarding. The browser app should sign you in and attach you to the managed backend automatically.</p>
            <ul class="mode-list">
              <li><strong>Best for:</strong> cross-device use without ops work</li>
              <li><strong>Transport:</strong> managed hosted MCP</li>
              <li><strong>Setup:</strong> account and connector onboarding</li>
            </ul>
            <a href="/cloud" class="mode-link">Open cloud overview →</a>
          </article>
        </div>
      </div>
    </section>

    <!-- PROBLEM / SOLUTION -->
    <section class="problem-sec">
      <div class="container">
        <div class="eyebrow">The problem</div>
        <h2 class="sec-title">Staying relevant is a<br /><em>full-time job.</em></h2>
        <p class="sec-body">You have genuine expertise. The internet produces infinite noise. Between them stands the daily grind of reading, filtering, and turning it into something worth saying.</p>

        <div class="ps-grid">
          <div data-reveal class="ps-col before">
            <span class="ps-tag before">Before Quillby</span>
            <ul class="ps-list">
              <li><span class="ps-icon">—</span><div><strong>45 minutes</strong> scanning feeds, newsletters, and Twitter to find one thing worth writing about.</div></li>
              <li><span class="ps-icon">—</span><div><strong>Blank page paralysis.</strong> You know your subject. You don't know where to start.</div></li>
              <li><span class="ps-icon">—</span><div><strong>Generic AI output.</strong> You try ChatGPT and it sounds like a LinkedIn HR bot.</div></li>
              <li><span class="ps-icon">—</span><div><strong>Posting irregularly</strong> because "finding something to say" isn't part of your actual job.</div></li>
            </ul>
          </div>
          <div data-reveal class="ps-col after">
            <span class="ps-tag after">With Quillby</span>
            <ul class="ps-list">
              <li><span class="ps-icon">↗</span><div>Ask Claude <strong>"what should I post today?"</strong> and get a ranked brief of what's actually relevant.</div></li>
              <li><span class="ps-icon">↗</span><div><strong>One-shot drafts</strong> sourced from real articles, structured as your kind of post.</div></li>
              <li><span class="ps-icon">↗</span><div><strong>Sounds like you</strong> — not a template. Quillby learns your voice from examples you approve.</div></li>
              <li><span class="ps-icon">↗</span><div><strong>Publish consistently</strong> without adding a single new tool, tab, or workflow to your day.</div></li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="how-sec" id="how-it-works">
      <div class="container">
        <div class="eyebrow">How it works</div>
        <h2 class="sec-title">Four steps.<br /><em>Zero new apps.</em></h2>
        <div class="steps-row">
          {[
            { n:'01', g:'⬇', title:'Install', desc:'Download the installer for your platform. Quillby wires itself into Claude Desktop automatically — no Terminal required.' },
            { n:'02', g:'◎', title:'Set up a workspace', desc:'Create one workspace per client, brand, newsletter, or Claude Project. Each one gets its own profile, memory, feeds, and drafts.' },
            { n:'03', g:'⌗', title:'Quillby reads the internet', desc:'RSS, Reddit, and Medium feeds are fetched, ranked by relevance to that workspace, and surfaced as a content brief.' },
            { n:'04', g:'↑', title:'Publish in your voice', desc:'Request a draft. Claude writes it from the workspace profile, memory, and sourced article. Edit, approve, post.' },
          ].map(s => (
            <div data-reveal class="step-card">
              <div class="step-num">{s.n}</div>
              <span class="step-glyph">{s.g}</span>
              <h3 class="step-title">{s.title}</h3>
              <p class="step-desc">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FEATURES -->
    <section class="feat-sec">
      <div class="container">
        <div class="eyebrow">What it does</div>
        <h2 class="sec-title">Content intelligence,<br /><em>built into your workflow.</em></h2>
        <div class="feat-grid">
          <div data-reveal class="feat-card">
            <div class="feat-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#a78bfa" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="2"/></svg>
            </div>
            <h3 class="feat-title">Reads the internet</h3>
            <p class="feat-desc">RSS feeds, Reddit communities, Medium articles — Quillby monitors sources that matter to your industry, in real time.</p>
          </div>
          <div data-reveal class="feat-card">
            <div class="feat-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#a78bfa" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            </div>
            <h3 class="feat-title">Stays on-topic</h3>
            <p class="feat-desc">Define your industry, audience, and excluded topics once. Quillby uses that profile to rank every article by relevance.</p>
          </div>
          <div data-reveal class="feat-card">
            <div class="feat-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#a78bfa" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            </div>
            <h3 class="feat-title">Writes in your voice</h3>
            <p class="feat-desc">No generic AI slop. Quillby sources the material and Claude writes the post — sounding like you, not a content farm.</p>
          </div>
          <div data-reveal class="feat-card">
            <div class="feat-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#a78bfa" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
            </div>
            <h3 class="feat-title">Learns over time</h3>
            <p class="feat-desc">Every draft you approve teaches Quillby your style. The more you use it, the less you edit.</p>
          </div>
          <div data-reveal class="feat-card">
            <div class="feat-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#a78bfa" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            </div>
            <h3 class="feat-title">One workspace per context</h3>
            <p class="feat-desc">Keep client work, personal brand, newsletters, and campaigns separated. Each workspace has its own profile, memory, feeds, and outputs.</p>
          </div>
          <div data-reveal class="feat-card">
            <div class="feat-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#a78bfa" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            </div>
            <h3 class="feat-title">Any industry, any language</h3>
            <p class="feat-desc">Healthcare, law, dev, finance, fashion — Quillby works for any niche, in any language Google News supports.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- INSTALL -->
    <section class="install-sec" id="install">
      <div class="container">
        <div class="eyebrow">Install</div>
        <h2 class="sec-title">Up and running<br /><em>in three minutes.</em></h2>

        <div class="install-wrap">
          <div>
            <div class="os-tabs-wrap" id="osTabs">
              <button class="os-tab active" data-os="mac">macOS</button>
              <button class="os-tab" data-os="win">Windows</button>
              <button class="os-tab" data-os="linux">Linux</button>
              <button class="os-tab" data-os="npm">npm</button>
            </div>

            <div id="os-mac">
              <a href="https://github.com/vncsleal/quillby/releases/latest/download/quillby-macos.pkg" class="dl-btn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Get Quillby for Mac
              </a>
              <p class="install-note">Works on Apple Silicon &amp; Intel. One double-click, no setup.<br />If macOS asks: right-click → <strong style="color:var(--text)">Open</strong>.</p>
            </div>

            <div id="os-win" class="hidden">
              <a href="https://github.com/vncsleal/quillby/releases/latest/download/quillby-windows.exe" class="dl-btn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Get Quillby for Windows
              </a>
              <p class="install-note">One double-click installer. No Terminal, no setup steps.</p>
            </div>

            <div id="os-linux" class="hidden">
              <div class="code-block">
                <div class="code-top"><span class="code-lang">bash</span><button class="copy-btn" data-copy={curlCommand}>copy</button></div>
                <div class="code-body">{curlCommand}</div>
              </div>
            </div>

            <div id="os-npm" class="hidden">
              <div class="code-block">
                <div class="code-top"><span class="code-lang">shell</span><button class="copy-btn" data-copy="npm install -g @vncsleal/quillby">copy</button></div>
                <div class="code-body">npm install -g @vncsleal/quillby</div>
              </div>
              <div class="code-block">
                <div class="code-top"><span class="code-lang">json · claude_desktop_config.json</span><button class="copy-btn" data-copy={claudeConfig}>copy</button></div>
                <div class="code-body" style="font-size:0.73rem;">{claudeConfig}</div>
