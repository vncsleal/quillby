    <script>
      document.querySelectorAll('.os-tab').forEach(btn => {
        btn.addEventListener('click', () => {
          const os = (btn as HTMLElement).dataset.os!;
          document.querySelectorAll('.os-tab').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          ['mac','win','linux','npm'].forEach(o => {
            document.getElementById('os-' + o)?.classList.toggle('hidden', o !== os);
          });
        });
      });

      document.querySelectorAll('.copy-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          navigator.clipboard.writeText((btn as HTMLElement).dataset.copy ?? '').catch(()=>{});
          btn.textContent = 'copied!';
          setTimeout(() => { btn.textContent = 'copy'; }, 1500);
        });
      });

      const ro = new IntersectionObserver(
        es => es.forEach(e => { if (e.isIntersecting) { e.target.classList.add('revealed'); ro.unobserve(e.target); } }),
        { threshold: 0.08 }
      );
      document.querySelectorAll('[data-reveal]').forEach(el => ro.observe(el));
    </script>
